<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= establishment.name %> - Community Insight Portal</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="bg-wallpaper light-theme" style="background-image: url('/assets/light-background.png');"></div>
    <div class="bg-wallpaper dark-theme" style="background-image: url('/assets/dark-background.png');"></div>

    <header class="navbar">
        <div class="nav-container">
            <div class="nav-left">
                <img src="/assets/logo.png" alt="Logo" class="logo-img">
                <h1 class="site-title">Community Portal</h1>
            </div>
            <div class="nav-center">
                <div class="search-wrapper">
                    <form method="GET" action="/" style="display: flex; width: 100%; gap: 0;">
                        <input type="text" id="searchBar" name="search" placeholder="🔍 Search establishments..." class="search-input">
                        <button type="submit" class="search-btn">Search</button>
                    </form>
                </div>
            </div>
            <div class="nav-right">
                <a href="/" class="nav-link">Home</a>
                <div class="nav-right">
    <a href="/" class="nav-link">Home</a>
    <% if (currentUser) { %>
        <a href="/profile" class="nav-link">Profile</a>
        <a href="/auth/logout" class="nav-link-btn login-btn">Logout</a>
    <% } else { %>
        <a href="/auth/login" class="nav-link-btn login-btn">Login</a>
        <a href="/auth/register" class="nav-link-btn signup-btn">Sign Up</a>
    <% } %>
                <button class="icon-btn" id="musicToggle" title="Toggle Music">
                    <img src="/assets/music-icon.png" alt="Music" class="icon-img">
                </button>
                <button class="icon-btn" id="darkModeToggle" title="Toggle Dark Mode">
                    <img src="/assets/lightbulb-icon.png" alt="Dark Mode" class="icon-img">
                </button>
            </div>
        </div>
    </header>

    <audio id="bgMusic" loop>
        <source src="/assets/background-music.mp3" type="audio/mpeg">
    </audio>
    <audio id="clickSound">
        <source src="/assets/click-sound.mp3" type="audio/mpeg">
    </audio>
    <audio id="successSound">
        <source src="/assets/success-sound.mp3" type="audio/mpeg">
    </audio>

    <main style="max-width: 1200px; margin: 20px auto; padding: 20px;">
        <div style="background: linear-gradient(135deg, #FFB6D9, #FF99CC); padding: 60px 30px; border-radius: 16px; color: white; margin-bottom: 30px;">
            <h1 style="font-size: 2.5rem; margin-bottom: 15px;"><%= establishment.name %></h1>
            <div style="font-size: 1.5rem; margin-bottom: 10px;">
                <span style="color: #FFD700;">★★★★★</span> <%= avgRating %> (<%= reviews.length %> reviews)
            </div>
            <p style="margin-bottom: 20px;"><%= establishment.description %></p>
            <% if (currentUser) { %>
                <a href="/reviews/create" style="display: inline-block; padding: 16px 36px; background: white; color: #FF66BC; text-decoration: none; border-radius: 30px; font-weight: bold; font-size: 1.2rem;">✍️ Write a Review</a>
            <% } else { %>
                <a href="/auth/login" style="display: inline-block; padding: 16px 36px; background: white; color: #FF66BC; text-decoration: none; border-radius: 30px; font-weight: bold; font-size: 1.2rem;">✍️ Login to Write a Review</a>
            <% } %>
        </div>

        <h3 style="font-size: 1.8rem; margin-bottom: 20px;">Reviews</h3>
        
        <% if (reviews.length === 0) { %>
            <div style="text-align: center; padding: 40px; background: white; border-radius: 16px;">
                <p style="font-size: 1.2rem; color: #999;">No reviews yet. Be the first to share your experience!</p>
            </div>
        <% } else { %>
            <% reviews.forEach(review => { %>
                <div class="review-card" style="background: white; padding: 25px; border-radius: 16px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(255,102,188,0.15);">
                    <div style="display: flex; gap: 15px; margin-bottom: 15px;">
                        <img src="/assets/default-avatar.jpg" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 3px solid #FF66BC;">
                        <div>
                            <a href="/profile/user/<%= review.user_id %>" style="color: #FF66BC; font-weight: bold; font-size: 1.1rem; text-decoration: none;"><%= review.username %></a>
                            <div style="color: #FFD700; margin: 5px 0;">
                                <% for (let i = 0; i < review.rating; i++) { %>★<% } %><% for (let i = review.rating; i < 5; i++) { %>☆<% } %>
                            </div>
                            <span style="color: #999; font-size: 0.9rem;">📅 <%= new Date(review.created_at).toLocaleDateString() %></span>
                        </div>
                    </div>
                    <h4 style="color: #FF66BC; font-size: 1.4rem; margin-bottom: 10px;"><%= review.title %></h4>
                    <p style="color: #555; line-height: 1.6; margin-bottom: 15px;"><%= review.body %></p>
                    <div style="margin-top: 15px; display: flex; gap: 10px;">
                        <button class="helpful-btn" onclick="markHelpful(<%= review.id %>)" style="padding: 8px 16px; border-radius: 20px; border: 2px solid #e0e0e0; background: white; cursor: pointer;">👍 Helpful (<%= review.helpful_count %>)</button>
                        <button class="unhelpful-btn" onclick="markUnhelpful(<%= review.id %>)" style="padding: 8px 16px; border-radius: 20px; border: 2px solid #e0e0e0; background: white; cursor: pointer;">👎 Unhelpful (<%= review.unhelpful_count %>)</button>
                    </div>
                    <% if (currentUser && currentUser.id === review.user_id) { %>
                        <div style="margin-top: 15px; display: flex; gap: 10px;">
                            <a href="/reviews/<%= review.id %>/edit" style="padding: 8px 16px; border-radius: 20px; border: 2px solid #FF66BC; background: white; color: #FF66BC; text-decoration: none; cursor: pointer;">Edit</a>
                            <form method="POST" action="/reviews/<%= review.id %>?_method=DELETE" style="display: inline;">
                                <button type="submit" style="padding: 8px 16px; border-radius: 20px; border: 2px solid #cc0000; background: white; color: #cc0000; cursor: pointer;">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } %>
    </main>

    <footer class="footer">
        <p>© 2026 Community Insight Portal. All rights reserved (Hypothetically). Made with Love and Effort 💖—by Group 11 for CCAPDEV</p>
    </footer>

    <script src="/js/script.js"></script>
    <script>
        function markHelpful(reviewId) {
            fetch(`/reviews/${reviewId}/helpful`, { method: 'POST' })
                .then(response => location.reload());
        }

        function markUnhelpful(reviewId) {
            fetch(`/reviews/${reviewId}/unhelpful`, { method: 'POST' })
                .then(response => location.reload());
        }
    </script>
</body>
</html>

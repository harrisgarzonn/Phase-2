<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Community Insight Portal</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="bg-wallpaper light-theme" style="background-image: url('/assets/light-background.png');"></div>
    <div class="bg-wallpaper dark-theme" style="background-image: url('/assets/dark-background.png');"></div>

    <header class="navbar">
        <div class="nav-container">
            <div class="nav-left">
                <img src="/assets/logo.png" alt="Logo" class="logo-img">
                <h1 class="site-title">Community Portal</h1>
            </div>
            <div class="nav-center">
                <div class="search-wrapper">
                    <form method="GET" action="/" style="display: flex; width: 100%; gap: 0;">
                        <input type="text" id="searchBar" name="search" placeholder="🔍 Search establishments..." class="search-input" value="<%= search || '' %>">
                        <button type="submit" class="search-btn">Search</button>
                    </form>
                </div>
            </div>
            <div class="nav-right">
    <a href="/" class="nav-link">Home</a>
    <% if (currentUser) { %>
        <a href="/profile" class="nav-link">Profile</a>
        <a href="/auth/logout" class="nav-link-btn login-btn">Logout</a>
    <% } else { %>
        <a href="/auth/login" class="nav-link-btn login-btn">Login</a>
        <a href="/auth/register" class="nav-link-btn signup-btn">Sign Up</a>
    <% } %>
                <button class="icon-btn" id="musicToggle" title="Toggle Music">
                    <img src="/assets/music-icon.png" alt="Music" class="icon-img">
                </button>
                <button class="icon-btn" id="darkModeToggle" title="Toggle Dark Mode">
                    <img src="/assets/lightbulb-icon.png" alt="Dark Mode" class="icon-img">
                </button>
            </div>
        </div>
    </header>

    <audio id="bgMusic" loop>
        <source src="/assets/background-music.mp3" type="audio/mpeg">
    </audio>
    <audio id="clickSound">
        <source src="/assets/click-sound.mp3" type="audio/mpeg">
    </audio>
    <audio id="successSound">
        <source src="/assets/success-sound.mp3" type="audio/mpeg">
    </audio>

    <main style="max-width: 1200px; margin: 20px auto; padding: 20px;">
        <div class="filter-section">
            <div class="filter-wrapper">
                <div class="category-chips">
                    <label class="chip <% if (currentCategory === 'all') { %>active<% } %>">
                        <input type="checkbox" class="category-filter" value="all" <% if (currentCategory === 'all') { %>checked<% } %>>
                        All
                    </label>
                    <label class="chip <% if (currentCategory === 'restaurant') { %>active<% } %>">
                        <input type="checkbox" class="category-filter" value="restaurant" <% if (currentCategory === 'restaurant') { %>checked<% } %>>
                        Restaurant
                    </label>
                    <label class="chip <% if (currentCategory === 'store') { %>active<% } %>">
                        <input type="checkbox" class="category-filter" value="store" <% if (currentCategory === 'store') { %>checked<% } %>>
                        Store
                    </label>
                    <label class="chip <% if (currentCategory === 'service') { %>active<% } %>">
                        <input type="checkbox" class="category-filter" value="service" <% if (currentCategory === 'service') { %>checked<% } %>>
                        Service
                    </label>
                </div>
                <div class="filter-controls">
                    <form method="GET" action="/" style="display: flex; gap: 15px; align-items: center;">
                        <input type="hidden" name="search" value="<%= search %>">
                        <select name="sort" class="sort-select" onchange="this.form.submit()">
                            <% sortOptions.forEach(opt => { %>
                                <option value="<%= opt.value %>" <% if (currentSort === opt.value) { %>selected<% } %>><%= opt.label %></option>
                            <% }); %>
                        </select>
                    </form>
                </div>
            </div>
        </div>

        <div class="establishments-container">
            <h2 class="section-title">Campus Establishments</h2>
            
            <div class="establishments-grid cols-3" id="establishmentsGrid">
                <% establishments.forEach(est => { %>
                    <div class="est-card" data-id="<%= est.id %>" data-name="<%= est.name %>" data-rating="<%= est.avg_rating || 0 %>" data-category="<%= est.category %>">
                        <div class="card-image-wrapper">
                            <img src="/assets/<%= est.name.toLowerCase().replace(/ /g, '') %>.jpg" alt="<%= est.name %>" onerror="this.src='/assets/establishment-default.jpg'">
                            <span class="badge <% if (est.category === 'restaurant') { %>restaurant-badge<% } else if (est.category === 'store') { %>store-badge<% } else { %>service-badge<% } %>">
                                <% if (est.category === 'restaurant') { %>🍔 Restaurant<% } else if (est.category === 'store') { %>🛍️ Store<% } else { %>⚙️ Service<% } %>
                            </span>
                            <div class="rating-badge">
                                <span class="stars">★★★★★</span>
                                <span class="num"><%= est.avg_rating || 'N/A' %></span>
                            </div>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title"><%= est.name %></h3>
                            <p class="card-description"><%= est.description %></p>
                            <div class="card-stats">
                                <span><%= est.review_count || 0 %> reviews</span>
                            </div>
                            <a href="/establishments/<%= est.id %>" style="display: inline-block; padding: 10px 20px; background-color: #FF66BC; color: white; text-decoration: none; border-radius: 20px; font-weight: 600; transition: all 0.2s;">View Details</a>
                        </div>
                    </div>
                <% }); %>
            </div>

            <% if (establishments.length === 0) { %>
                <div style="text-align: center; padding: 40px;">
                    <p style="font-size: 1.2rem; color: #999;">No establishments found. Try a different search.</p>
                </div>
            <% } %>

            <div style="background: linear-gradient(135deg, #FFB6D9, #FF99CC); padding: 40px; border-radius: 16px; text-align: center; margin-top: 30px;">
                <h3 style="font-size: 1.8rem; color: white; margin-bottom: 15px;">Know a great establishment?</h3>
                <a href="/reviews/create" style="display: inline-block; padding: 16px 40px; background: white; color: #FF66BC; text-decoration: none; border-radius: 30px; font-weight: bold; font-size: 1.2rem;">Write Your Review</a>
            </div>
        </div>
    </main>

    <footer class="footer">
        <p>© 2026 Community Insight Portal. All rights reserved (Hypothetically). Made with Love and Effort 💖—by Group 11 for CCAPDEV</p>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>
